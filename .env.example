# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# App
NEXT_PUBLIC_SITE_URL=http://localhost:4000
SESSION_COOKIE_SECRET=

# Email — Gmail SMTP. Generate an App Password at
# https://myaccount.google.com/apppasswords (requires 2-Step Verification).
# Soft cap ~500/day. Sends to anyone. Leave blank to no-op email sends.
GMAIL_USER=
GMAIL_APP_PASSWORD=
GMAIL_FROM_NAME=Hotel Vardani

# Google Places (Reviews cache — Places API New). Get a key from
# console.cloud.google.com → APIs & Services. Enable "Places API (New)".
GOOGLE_PLACES_API_KEY=

# Cron / scheduled jobs. Used by /api/cron/* routes to authorize the
# scheduled Vercel cron invocations. Generate with `openssl rand -hex 32`.
CRON_SECRET=
